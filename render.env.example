# =============================================================================
# RENDER — Variables de entorno (copiar al dashboard al desplegar Blueprint)
# =============================================================================
# Render → New → Blueprint → conecta repo → te pedirá las marcadas (sync: false)
#
# Las URLs VITE_API_URL y VITE_AI_API_URL las conecta render.yaml solo.
# NO las pegues a mano en el frontend.
# =============================================================================


# ── SERVICIO 1: contam-erp (Frontend Node) ─────────────────────────────────
# Archivo local de referencia: .env (raíz del proyecto)

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...tu_anon_key...

# Ya vienen en render.yaml (no pegar):
# NODE_ENV=production
# VITE_USE_NEW_SIRE_STRUCTURE=true
# VITE_USE_DJANGO_API=true
# VITE_ENABLE_PERFORMANCE_MONITORING=false
# VITE_API_URL → auto desde contam-django
# VITE_AI_API_URL → auto desde contam-ai


# ── SERVICIO 2: contam-django (Backend Python) ───────────────────────────────
# Archivo local de referencia: backend/.env
# Render pide DB aquí (contam-ai las copia automáticamente desde django).

DJANGO_SECRET_KEY=genera-un-string-largo-aleatorio-minimo-50-caracteres
DB_NAME=postgres
DB_USER=postgres.TU_PROJECT_REF
DB_PASSWORD=tu_password_supabase
DB_HOST=aws-0-us-east-1.pooler.supabase.com

# Ya vienen en render.yaml (no pegar):
# DB_PORT=5432
# DB_SSLMODE=require

# Ya vienen en render.yaml (no pegar):
# PYTHON_VERSION=3.12.0
# DJANGO_DEBUG=false


# ── SERVICIO 3: contam-ai (AI Agent FastAPI) ─────────────────────────────────
# Archivo local de referencia: ai-agent/server/.env

MISTRAL_API_KEY=tu_api_key_de_mistral

# DB: NO pegar en contam-ai — render.yaml las toma de contam-django automáticamente.

# SUNAT (para herramientas del agente IA):
SUNAT_CLIENT_ID=tu_client_id_sunat
SUNAT_CLIENT_SECRET=tu_client_secret_sunat

# Ya vienen en render.yaml (no pegar):
# PYTHON_VERSION=3.12.0
# MISTRAL_MODEL=mistral-small-latest

# Opcionales (tienen default, solo si quieres cambiar):
# ASK_MAX_THINKING_SECONDS=15
# COMPOSER_MAX_THINKING_SECONDS=45
# DEBUG_MAX_THINKING_SECONDS=30


# =============================================================================
# NO van en Render (van en Supabase Edge Functions secrets):
# =============================================================================
# npx supabase secrets set SUNAT_CLIENT_ID="..."
# npx supabase secrets set SUNAT_CLIENT_SECRET="..."
# npx supabase secrets set API_SUNAT_TOKEN="..."
#
# Edge Functions a desplegar en Supabase (SIRE + AI Copilot página):
# npx supabase functions deploy sire-sync
# npx supabase functions deploy consultar-ruc
# npx supabase functions deploy contam-ai-copilot
# =============================================================================
