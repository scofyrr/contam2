# Supabase (obligatorio)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key

# Feature flags (opcional — default false)
VITE_USE_NEW_SIRE_STRUCTURE=false
VITE_USE_DJANGO_API=false

# Django API (solo si VITE_USE_DJANGO_API=true)
VITE_API_URL=http://127.0.0.1:8000

# Agente IA (opcional)
VITE_AI_API_URL=http://127.0.0.1:8001

# Performance monitoring (opcional — false en prod si no se usa)
VITE_ENABLE_PERFORMANCE_MONITORING=false
