# =============================================================================
# CONTAM ERP — Variables de entorno (cliente Vite)
# =============================================================================

# Habilita el uso obligatorio de las tablas normalizadas del SIRE
# (registros_sire_cabecera + registros_sire_montos). Debe ser true en producción.
VITE_USE_NEW_SIRE_STRUCTURE=true

# URL y llave pública de Supabase (obligatorio)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key

# =============================================================================
# SUNAT / SIRE — Credenciales API (NO van en este archivo)
# =============================================================================
# SUNAT OAuth2 (obligatorio para sire-sync / propuesta SIRE):
#   npx supabase secrets set SUNAT_CLIENT_ID="tu_client_id"
#   npx supabase secrets set SUNAT_CLIENT_SECRET="tu_client_secret"
#
# API_SUNAT_TOKEN — solo para consultar-ruc (Decolecta). NO existe endpoint SIRE propuesta en Decolecta.
#   npx supabase secrets set API_SUNAT_TOKEN="tu_bearer_token"
#
# Opcional — solo desarrollo/demo (permite simulación explícita en Edge Functions):
#   npx supabase secrets set ALLOW_MOCK_FALLBACK=true
#
# Despliegue Edge Functions SIRE:
#   npx supabase functions deploy sire-sync
#   npx supabase functions deploy consultar-ruc
# =============================================================================

# Feature flags adicionales (opcional)
VITE_USE_DJANGO_API=false

# Django API (solo si VITE_USE_DJANGO_API=true)
VITE_API_URL=http://127.0.0.1:8000

# Agente IA (opcional)
VITE_AI_API_URL=http://127.0.0.1:8001

# Performance monitoring (opcional — false en prod si no se usa)
VITE_ENABLE_PERFORMANCE_MONITORING=false
